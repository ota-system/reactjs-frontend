{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useExhaustiveDependencies": "warn",
				"noUnusedImports": {
					"level": "error",
					"fix": "safe"
				}
			},
			"nursery": {
				"noShadow": "off"
			},
			"style": {
				"noMagicNumbers": "off",
				"noNonNullAssertion": "off",
				"noEnum": "off",
				"useFilenamingConvention": "off",
				"noExportedImports": "off",
				"useBlockStatements": {
					"level": "warn",
					"fix": "safe"
				}
			},
			"suspicious": {
				"noArrayIndexKey": "on",
				"noUnknownAtRules": "off",
				"noConsole": {
					"level": "on",
					"options": {
						"allow": ["assert", "error", "info", "warn"]
					}
				}
			},
			"performance": {
				"noBarrelFile": "off",
				"noNamespaceImport": "info",
				"noDynamicNamespaceImportAccess": "info"
			},
			"a11y": {
				"noSvgWithoutTitle": "off"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "info",
					"options": {
						"maxAllowedComplexity": 30
					}
				}
			},
			"security": {
				"noSecrets": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/components/ui/**", "src/shared/hooks/shadcn/**"],
			"formatter": {
				"enabled": false
			},
			"linter": {
				"enabled": false
			},
			"assist": {
				"actions": {
					"source": {
						"useSortedAttributes": "off",
						"organizeImports": "off"
					}
				}
			}
		}
	]
}
