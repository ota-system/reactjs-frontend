		"clsx": "^2.1.1",
		"jwt-decode": "^4.0.0",
		"lucide-react": "^1.8.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.72.1",
